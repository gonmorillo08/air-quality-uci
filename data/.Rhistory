rm(list=ls())
# Funcion del algoritmo ----
newton_unidim = function(fun, dfun, d2fun, x0,epsilon=0.0001,itermax=100,
report.calculos=TRUE) {
k = 1
xk = x0
mres = NULL
repeat {
fx = fun(xk)
dfx = dfun(xk)
d2fx = d2fun(xk)
xk1 = xk - dfx/d2fx
vres = c(k, xk, fx, dfx, d2fx, xk1)
if (report.calculos) {
if (is.null(mres)) mres = vres
else mres = rbind(mres, vres)
}
if (abs(xk1 - xk) < epsilon || k >= itermax) break
xk = xk1
k = k + 1
}
colnames(mres) = c("k","xk","f(xk)","f'(xk)","f''(xk)","xk+1")
return(as.data.frame(mres))
}
fun = \(x) x^2 + 2*x
dfun = \(x) 2*x + 2
d2fun = \(x) 2
res = newton_unidim(fun, dfun, d2fun, x0=0)
res   #Observamos que se alcanza el mínimo en xk = -1
curve(fun, -2, 1)
title(main='Metodo de Newton para f(x)=x^2 + 2x')
points(res$xk, res$`f(xk)`, col="red", pch=19)
lines(res$xk, res$`f(xk)`, col="red")
fun = \(x) 6*x^2 + 5*x
dfun = \(x) 12*x + 5
d2fun = \(x) 12
res = newton_unidim(fun, dfun, d2fun, x0=2)
res
curve(fun, -3, 7)
title(main='Metodo de Newton para f(x)=6x^2 + 5x')
points(res$xk, res$`f(xk)`, col="red", pch=19)
lines(res$xk, res$`f(xk)`, col="red")
