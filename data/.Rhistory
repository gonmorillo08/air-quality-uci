fun = function(v) (v[1]-2)^4 + (v[1]-2*v[2])^2
grad = function(v) {
c(4*(v[1]-2)^3 + 2*(v[1]-2*v[2]),
-4*(v[1]-2*v[2]))
}
hess = function(v) {
matrix(c(
12*(v[1]-2)^2 + 2, -4,
-4, 8
),2,2)
}
