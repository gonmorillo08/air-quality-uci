newton_multi = function(fun, grad, hess, x0,
epsilon=0.0001, maxiter=1000) {
xk = x0
path = matrix(x0, nrow=1)
k = 1
repeat {
g = grad(xk)
H = hess(xk)
xk1 = xk - solve(H) %*% g
xk1 = as.vector(xk1)
path = rbind(path, xk1)
if (sqrt(sum((xk1 - xk)^2)) < epsilon || k > maxiter) break
xk = xk1
k = k + 1
}
return(list(sol=xk1, path=path))
}
