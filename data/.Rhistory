gradfunx = function(vx) c(4*(vx[1]-2)^3+2*(vx[1]-2*vx[2]),-4*(vx[1]-2*vx[2]))
hessfunx = function(vx) matrix(c(12*(vx[1]-2)^2+2,-4,-4,8),nrow = 2,ncol = 2,byrow=TRUE)
df.res = optmul_nores_newtonmult(funx,gradfunx,hessfunx,vx.ini,epsilon=0.0001,nummax.iter = 1000,
report.calculos=T)
