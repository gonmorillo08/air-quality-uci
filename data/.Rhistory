rm(list=ls())
# Funcion del algoritmo ----
hooke_jeeves = function(fun, x0, delta=0.5,
alpha=2, epsilon=0.0001,
itermax=1000) {
n = length(x0)
x_base = x0
k = 0
path = matrix(x0, nrow=1)
busca_nuevo_punto = function(x, delta) {
x_nuevo = x
for (i in 1:n) {
f0 = fun(x_nuevo)
x1 = x_nuevo
x1[i] = x1[i] + delta
if (fun(x1) < f0) {
x_nuevo = x1
} else {
x2 = x_nuevo
x2[i] = x2[i] - delta
if (fun(x2) < f0) x_nuevo = x2
}
}
return(x_nuevo)
}
repeat {
k = k + 1
x_exp = busca_nuevo_punto(x_base, delta)
if (all(x_exp == x_base)) {
delta = delta / 2
} else {
x_pattern = x_exp + alpha * (x_exp - x_base)
x_base = x_exp
path = rbind(path, x_base)
}
if (delta < epsilon || k > itermax) break
}
return(list(sol=x_base, path=path))
}
# Resultado ----
fun = function(v) (v[1]-2)^4 + (v[1]-2*v[2])^2
res = hooke_jeeves(fun, c(0,3))
res$sol
